<%- include('../partials', { title: 'Products', user: user }) %>
<% editingProduct = typeof editingProduct !== 'undefined' ? editingProduct : null; %>
<% products = typeof products !== 'undefined' ? products : []; %>
<% categories = typeof categories !== 'undefined' ? categories : []; %>
<% brands = typeof brands !== 'undefined' ? brands : []; %>
<div class="card">
  <form method="post" action="<%= editingProduct ? '/products/edit/' + editingProduct.id : '/products' %>" class="form-grid">
    <div class="topbar">
      <h2>Products</h2>
      <button class="btn" type="submit"><%= editingProduct ? 'Update Product' : 'Add Product' %></button>
    </div>
    <div class="input-group">
      <label>Product name</label>
      <input name="product_name" placeholder="Name" value="<%= editingProduct ? editingProduct.product_name : '' %>" required />
    </div>
    <div class="input-group">
      <label>SKU / Barcode</label>
      <input name="sku_barcode" placeholder="SKU / Barcode" value="<%= editingProduct ? editingProduct.sku_barcode || '' : '' %>" />
    </div>
    <div class="input-group">
      <label>Category</label>
      <select name="category_id">
        <option value="">Category</option>
        <% categories.forEach(category => { %>
          <option value="<%= category.id %>" <%= editingProduct && editingProduct.category_id == category.id ? 'selected' : '' %>><%= category.category_name %></option>
        <% }); %>
      </select>
    </div>
    <div class="input-group">
      <label>Brand</label>
      <select name="brand_id">
        <option value="">Brand</option>
        <% brands.forEach(brand => { %>
          <option value="<%= brand.id %>" <%= editingProduct && editingProduct.brand_id == brand.id ? 'selected' : '' %>><%= brand.brand_name %></option>
        <% }); %>
      </select>
    </div>
    <div class="input-group">
      <label>Unit</label>
      <select name="unit">
        <option value="Pcs" <%= editingProduct && editingProduct.unit == 'Pcs' ? 'selected' : '' %>>Pcs</option>
        <option value="Kg" <%= editingProduct && editingProduct.unit == 'Kg' ? 'selected' : '' %>>Kg</option>
        <option value="Feet" <%= editingProduct && editingProduct.unit == 'Feet' ? 'selected' : '' %>>Feet</option>
        <option value="Bag" <%= editingProduct && editingProduct.unit == 'Bag' ? 'selected' : '' %>>Bag</option>
        <option value="Roll" <%= editingProduct && editingProduct.unit == 'Roll' ? 'selected' : '' %>>Roll</option>
      </select>
    </div>
    <div class="input-group">
      <label>Purchase price</label>
      <input name="purchase_price" type="number" step="0.01" placeholder="Purchase price" value="<%= editingProduct ? editingProduct.purchase_price : 0 %>" required />
    </div>
    <div class="input-group">
      <label>Selling price</label>
      <input name="selling_price" type="number" step="0.01" placeholder="Selling price" value="<%= editingProduct ? editingProduct.selling_price : 0 %>" required />
    </div>
    <div class="input-group">
      <label>Stock quantity</label>
      <input name="current_stock_qty" type="number" step="0.01" placeholder="Stock qty" value="<%= editingProduct ? editingProduct.current_stock_qty : 0 %>" />
    </div>
    <div class="input-group">
      <label>Min stock alert</label>
      <input name="min_stock_alert" type="number" step="0.01" placeholder="Min stock alert" value="<%= editingProduct ? editingProduct.min_stock_alert : 5 %>" />
    </div>
    <% if (editingProduct) { %><a class="btn secondary" href="/products">Cancel</a><% } %>
  </form>
</div>
<div class="card">
  <table class="table">
    <thead><tr><th>ID</th><th>Name</th><th>Category</th><th>Brand</th><th>SKU</th><th>Unit</th><th>Stock</th><th>Sell Price</th><th>Action</th></tr></thead>
    <tbody>
      <% products.forEach(product => { %>
        <tr>
          <td><%= product.id %></td>
          <td><%= product.product_name %></td>
          <td><%= product.category_name || '-' %></td>
          <td><%= product.brand_name || '-' %></td>
          <td><%= product.sku_barcode || '-' %></td>
          <td><%= product.unit %></td>
          <td><%= (product.current_stock_qty || 0).toFixed(2) %></td>
          <td><%= (product.selling_price || 0).toFixed(2) %></td>
          <td class="invoice-actions">
            <a class="btn secondary" href="/products/edit/<%= product.id %>">Edit</a>
            <form method="post" action="/products/delete" onsubmit="return confirm('Delete this product?');" style="display:inline-block;">
              <input type="hidden" name="product_id" value="<%= product.id %>" />
              <button class="btn secondary" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<footer>Manage all products and pricing in your store.</footer>
</main>
</div>
</body>
</html>

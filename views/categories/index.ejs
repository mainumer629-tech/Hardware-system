<%- include('../partials', { title: 'Categories', user: user }) %>
<div class="card">
  <div class="topbar">
    <h2>Categories</h2>
  </div>
  <form method="post" action="/categories" class="form-grid">
    <div class="input-group">
      <label>Category name</label>
      <input name="category_name" placeholder="New category" required />
    </div>
    <div></div>
    <button class="btn" type="submit">Add Category</button>
  </form>
</div>
<div class="card">
  <table class="table">
    <thead><tr><th>ID</th><th>Category</th></tr></thead>
    <tbody>
      <% categories.forEach(category => { %>
        <tr><td><%= category.id %></td><td><%= category.category_name %></td></tr>
      <% }); %>
    </tbody>
  </table>
</div>
<footer>Manage category types used for product organization.</footer>
</main>
</div>
</body>
</html>

<%- include('../partials', { title: 'Sales Invoice', user: user }) %>
<div id="invoice-preview">
  <div class="card">
    <div class="topbar">
      <h2>Invoice #<%= invoice.id %></h2>
      <button class="btn" onclick="window.print()">Print Invoice</button>
    </div>
    <div class="print-receipt">
    <div class="receipt-header">
      <div class="logo-placeholder"></div>
      <h1>AHMAD HARDWARE SHOP</h1>
      <p class="receipt-tagline">Sales Voucher</p>
    </div>
    <div class="receipt-meta">
      <table>
        <tbody>
          <tr><td>Invoice #</td><td><%= invoice.id %></td></tr>
          <tr><td>Date</td><td><%= new Date(invoice.invoice_date).toLocaleString() %></td></tr>
          <tr><td>Cashier</td><td><%= invoice.cashier %></td></tr>
          <tr><td>Payment</td><td><%= invoice.payment_type %></td></tr>
        </tbody>
      </table>
    </div>
    <div class="receipt-customer">
      <table>
        <tbody>
          <tr><td>Customer</td><td><%= invoice.customer_name || 'Walk-in' %></td></tr>
          <tr><td>Phone</td><td><%= invoice.customer_phone || '-' %></td></tr>
        </tbody>
      </table>
    </div>
    <div class="receipt-items">
      <table>
        <thead>
          <tr><th>Item</th><th>Qty</th><th>Price</th><th>Total</th></tr>
        </thead>
        <tbody>
          <% invoice.items.forEach(item => { %>
            <tr>
              <td><%= item.product_name || 'Product' %></td>
              <td><%= item.qty_sold %></td>
              <td><%= item.unit_price.toFixed(2) %></td>
              <td><%= item.total_price.toFixed(2) %></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
    <div class="receipt-summary">
      <table>
        <tbody>
          <tr><td>Discount</td><td><%= invoice.discount.toFixed(2) %></td></tr>
          <tr><td>Total Amount</td><td><%= invoice.grand_total.toFixed(2) %></td></tr>
          <tr><td>Amount Received</td><td><%= invoice.amount_received.toFixed(2) %></td></tr>
          <tr><td>Balance Due</td><td><%= invoice.balance_due.toFixed(2) %></td></tr>
        </tbody>
      </table>
    </div>
    <div class="receipt-footer">
      <p>Thank you for shopping at AHMAD HARDWARE SHOP.</p>
      <p>Please visit again.</p>
    </div>
  </div>
</div>
</div>
<footer>Print or view the invoice for this sale.</footer>
</main>
</body>
</html>

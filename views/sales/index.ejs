<%- include('../partials', { title: 'Sales', user: user }) %>
<% printInvoice = typeof printInvoice !== 'undefined' ? printInvoice : null; %>
<div class="card">
  <form method="post" action="/sales" class="form-grid">
    <div class="topbar">
      <h2>Sales Management</h2>
      <div class="topbar-actions">
        <button id="print-invoice-button" class="btn secondary" type="button" <%= (typeof printInvoice !== 'undefined' && printInvoice) ? '' : 'disabled' %>>Print Invoice</button>
        <button class="btn" type="submit">Add Sale</button>
      </div>
    </div>
    <div class="input-group">
      <label>Customer</label>
      <select name="customer_id" required>
        <option value="">Choose customer</option>
        <% customers.forEach(customer => { %>
          <option value="<%= customer.id %>"><%= customer.customer_name %></option>
        <% }); %>
      </select>
    </div>
    <div class="input-group">
      <label>Product</label>
      <select name="product_id" required>
        <option value="">Choose product</option>
        <% products.forEach(product => { %>
          <option value="<%= product.id %>"><%= product.product_name %> - <%= product.current_stock_qty.toFixed(2) %> in stock</option>
        <% }); %>
      </select>
    </div>
    <div class="input-group">
      <label>Qty sold</label>
      <input name="qty_sold" type="number" step="0.01" placeholder="Qty sold" required />
    </div>
    <div class="input-group">
      <label>Unit price</label>
      <input name="unit_price" type="number" step="0.01" placeholder="Unit price" required />
    </div>
    <div class="input-group">
      <label>Discount</label>
      <input name="discount" type="number" step="0.01" placeholder="Discount" value="0" />
    </div>
    <div class="input-group">
      <label>Payment type</label>
      <select name="payment_type">
        <option value="Cash">Cash</option>
        <option value="Bank">Bank</option>
        <option value="Khata/Credit">Khata/Credit</option>
      </select>
    </div>
    <div class="input-group">
      <label>Amount received</label>
      <input name="amount_received" type="number" step="0.01" placeholder="Amount received" required />
    </div>
    <div></div>
    <button class="btn" type="submit">Create Invoice</button>
  </form>
</div>
<div class="card">
  <table class="table">
    <thead><tr><th>ID</th><th>Customer</th><th>Salesman</th><th>Total</th><th>Paid</th><th>Balance</th><th>Date</th><th>Action</th></tr></thead>
    <tbody>
      <% invoices.forEach(invoice => { %>
        <tr>
          <td><%= invoice.id %></td>
          <td><%= invoice.customer_name || '-' %></td>
          <td><%= invoice.salesman || '-' %></td>
          <td><%= invoice.grand_total.toFixed(2) %></td>
          <td><%= invoice.amount_received.toFixed(2) %></td>
          <td><%= invoice.balance_due.toFixed(2) %></td>
          <td><%= invoice.invoice_date %></td>
          <td class="invoice-actions">
            <a href="/sales/invoice/<%= invoice.id %>" class="btn secondary">View Invoice</a>
            <form method="post" action="/sales/delete" onsubmit="return confirm('Delete this invoice and its items?');" style="display:inline-block; margin-left:6px;">
              <input type="hidden" name="invoice_id" value="<%= invoice.id %>" />
              <button class="btn secondary" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
</body>
</html>

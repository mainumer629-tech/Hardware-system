<%- include('../partials', { title: 'Purchases', user: user }) %>
<% editingPurchase = typeof editingPurchase !== 'undefined' ? editingPurchase : null; %>
<% purchases = typeof purchases !== 'undefined' ? purchases : []; %>
<% suppliers = typeof suppliers !== 'undefined' ? suppliers : []; %>
<% products = typeof products !== 'undefined' ? products : []; %>
<div class="card">
  <form method="post" action="<%= editingPurchase ? '/purchases/edit/' + editingPurchase.id : '/purchases' %>" class="form-grid">
    <div class="topbar">
      <h2>Purchase Management</h2>
      <button class="btn" type="submit"><%= editingPurchase ? 'Update Purchase' : 'Save Purchase' %></button>
    </div>
    <div class="input-group">
      <label>Supplier</label>
      <select name="supplier_id" required>
        <option value="">Choose supplier</option>
        <% suppliers.forEach(supplier => { %>
          <option value="<%= supplier.id %>" <%= editingPurchase && editingPurchase.supplier_id == supplier.id ? 'selected' : '' %>><%= supplier.supplier_name %></option>
        <% }); %>
      </select>
    </div>
    <% if (!editingPurchase) { %>
      <div class="input-group">
        <label>Product</label>
        <select name="product_id" required>
          <option value="">Choose product</option>
          <% products.forEach(product => { %>
            <option value="<%= product.id %>"><%= product.product_name %></option>
          <% }); %>
        </select>
      </div>
      <div class="input-group">
        <label>Qty purchased</label>
        <input name="qty_purchased" type="number" step="0.01" placeholder="Qty purchased" required />
      </div>
      <div class="input-group">
        <label>Unit cost</label>
        <input name="unit_cost" type="number" step="0.01" placeholder="Unit cost" required />
      </div>
    <% } %>
    <div class="input-group">
      <label>Paid amount</label>
      <input name="paid_amount" type="number" step="0.01" placeholder="Paid amount" value="<%= editingPurchase ? editingPurchase.paid_amount : 0 %>" required />
    </div>
    <% if (editingPurchase) { %><a class="btn secondary" href="/purchases">Cancel</a><% } %>
  </form>
</div>
<div class="card">
  <table class="table">
    <thead><tr><th>ID</th><th>Supplier</th><th>Total</th><th>Paid</th><th>Due</th><th>Date</th><th>Action</th></tr></thead>
    <tbody>
      <% purchases.forEach(purchase => { %>
        <tr>
          <td><%= purchase.id %></td>
          <td><%= purchase.supplier_name || '-' %></td>
          <td><%= purchase.total_amount.toFixed(2) %></td>
          <td><%= purchase.paid_amount.toFixed(2) %></td>
          <td><%= purchase.due_amount.toFixed(2) %></td>
          <td><%= purchase.purchase_date %></td>
          <td class="invoice-actions">
            <a class="btn secondary" href="/purchases/edit/<%= purchase.id %>">Edit</a>
            <form method="post" action="/purchases/delete" onsubmit="return confirm('Delete this purchase?');" style="display:inline-block;">
              <input type="hidden" name="purchase_id" value="<%= purchase.id %>" />
              <button class="btn secondary" type="submit">Delete</button>
            </form>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<footer>Record purchase orders and inventory stock additions.</footer>
</main>
</div>
</body>
</html>
